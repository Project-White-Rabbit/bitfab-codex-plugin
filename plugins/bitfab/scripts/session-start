#!/usr/bin/env sh
# SessionStart hook: prints plugin-update / SDK-update / not-authenticated
# banners to stdout (Codex forwards them as "extra developer context").
#
# Invoked two ways:
#   1. If Codex auto-discovers the plugin-shipped hooks.json (speculative -
#      undocumented as of Apr 2026), the hook fires at session start with
#      $0 pointing into the installed plugin cache. The self-resolver
#      below picks up the real root from $0's directory.
#   2. If the user wires it manually in `~/.codex/hooks.json`, they point
#      `command` at a find-based resolver that ultimately exec's this
#      script - same self-resolver path.

set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

if [ -n "${NODE_OPTIONS:-}" ]; then
  unset NODE_OPTIONS
fi

NODE_CMD="node"
if [ -n "${NODE_BIN:-}" ] && [ -x "${NODE_BIN}" ]; then
  NODE_CMD="${NODE_BIN}"
elif ! command -v node >/dev/null 2>&1; then
  # No node available - silently no-op rather than break session start.
  exit 0
fi

exec "$NODE_CMD" "$ROOT/dist/hooks/sessionStart.js" "$@"
